# Unified worker: BullMQ processors + scheduler in one process.
# It consumes the same env schema as the API (validated by
# packages/server/src/config/env.schema.ts).

# ----------------------------------------------------------------------------
# Runtime
# ----------------------------------------------------------------------------
NODE_ENV=development

# ----------------------------------------------------------------------------
# Postgres / Redis
# ----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/seotracker
PG_POOL_MAX=10
PG_POOL_IDLE_TIMEOUT_MS=30000
PG_POOL_CONNECTION_TIMEOUT_MS=5000
REDIS_URL=redis://localhost:6379

# ----------------------------------------------------------------------------
# Auth
# ----------------------------------------------------------------------------
JWT_ACCESS_SECRET=__REPLACE_ME__openssl_rand_base64_48
JWT_REFRESH_SECRET=__REPLACE_ME__openssl_rand_base64_48

# ----------------------------------------------------------------------------
# SMTP
# ----------------------------------------------------------------------------
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="SEOTracker <no-reply@seotracker.local>"

# Frontend URL — used in transactional email links
APP_URL=http://localhost:3000

# ----------------------------------------------------------------------------
# Queue tuning
# ----------------------------------------------------------------------------
AUDIT_CONCURRENCY_GLOBAL=4
AUDIT_CONCURRENCY_PER_PROJECT=1
AUDIT_QUEUE_ATTEMPTS=3
AUDIT_HTTP_TIMEOUT_MS=15000
# Total attempts per transient outbound fetch (timeouts, 429, 5xx). Keep small:
# every retry spends audit time and remote crawl budget.
AUDIT_FETCH_RETRY_ATTEMPTS=2
AUDIT_MAX_LINKS=20
AUDIT_MAX_PAGES=12
AUDIT_MAX_DEPTH=2
AUDIT_SITEMAP_SAMPLE_MAX=50
# Per-page <a href> discovery cap and per-run sitemap fetch cap.
AUDIT_MAX_LINKS_PER_PAGE=40
AUDIT_MAX_SITEMAPS_PER_RUN=8
# Identify the crawler with a reachable contact URL — some sites bot-gate
# user agents whose URL doesn't resolve.
AUDIT_USER_AGENT=SEOTrackerBot/1.0 (+https://github.com/TheHypnoo/SeoTracker)

# Optional for internal ScoreV2 calibration against Google PageSpeed Insights.
# The calibration script can also run without credentials, but authenticated
# calls are better for repeated automated batches. API key is preferred for
# internal benchmarks; OAuth works when a valid access token or refresh token is
# available.
# PAGESPEED_API_KEY=
# PAGESPEED_OAUTH_ACCESS_TOKEN=
# PAGESPEED_OAUTH_REFRESH_TOKEN=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

EXPORT_CONCURRENCY=2
EXPORT_QUEUE_ATTEMPTS=3
EXPORT_TTL_HOURS=48

# Object storage for generated export files. Must match the API service so the
# worker writes where the API reads.
#   fs → local directory (dev, or docker-compose with a shared volume)
#   s3 → S3-compatible bucket (Cloudflare R2 / AWS S3 / Backblaze B2) for prod
STORAGE_DRIVER=fs
STORAGE_FS_DIR=../../storage
# Required when STORAGE_DRIVER=s3:
# STORAGE_S3_ENDPOINT=https://<account>.r2.cloudflarestorage.com
# STORAGE_S3_REGION=auto
# STORAGE_S3_BUCKET=seotracker-exports
# STORAGE_S3_ACCESS_KEY_ID=
# STORAGE_S3_SECRET_ACCESS_KEY=
# STORAGE_S3_FORCE_PATH_STYLE=false

OUTBOUND_CONCURRENCY=5
OUTBOUND_QUEUE_ATTEMPTS=5

EMAIL_CONCURRENCY=3
EMAIL_QUEUE_ATTEMPTS=5

# ----------------------------------------------------------------------------
# Search Console import (daily cron + backfill)
# ----------------------------------------------------------------------------
GSC_IMPORT_CONCURRENCY=2
GSC_IMPORT_QUEUE_ATTEMPTS=3
GSC_BACKFILL_MONTHS=16
# The worker refreshes Google OAuth access tokens during scheduled imports, so it needs the
# same Google credentials and token encryption key as the API.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:4000/api/v1/google/oauth/callback
GOOGLE_TOKEN_ENCRYPTION_KEY=__REPLACE_ME__openssl_rand_base64_48

# ----------------------------------------------------------------------------
# Scheduling
# ----------------------------------------------------------------------------
SCHEDULER_LOCK_KEY=scheduler:run-due-schedules
SCHEDULER_LOCK_TTL_MS=90000
SCHEDULER_DUE_WINDOW_MINUTES=5

# ----------------------------------------------------------------------------
# Worker HTTP server (health + metrics)
# ----------------------------------------------------------------------------
JOBS_HTTP_PORT=4101

# ----------------------------------------------------------------------------
# Observability
# ----------------------------------------------------------------------------
METRICS_TOKEN=
BULLMQ_METRICS_INTERVAL_MS=15000
OTEL_ENABLED=false
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_SERVICE_NAME=seotracker-worker
