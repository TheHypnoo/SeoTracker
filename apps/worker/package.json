{
  "name": "worker",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "pnpm clean && tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "lint": "NODE_OPTIONS=--experimental-strip-types oxlint --ignore-path ../../.gitignore src",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "check": "pnpm format && NODE_OPTIONS=--experimental-strip-types oxlint --ignore-path ../../.gitignore --fix src",
    "format": "NODE_OPTIONS=--experimental-strip-types oxfmt --ignore-path ../../.gitignore --write src",
    "format:check": "NODE_OPTIONS=--experimental-strip-types oxfmt --ignore-path ../../.gitignore --check src"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.19",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.19",
    "@nestjs/event-emitter": "^3.1.0",
    "@nestjs/schedule": "^6.1.3",
    "@seotracker/server": "workspace:*",
    "nestjs-pino": "^4.6.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
