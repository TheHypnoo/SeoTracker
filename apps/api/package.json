{
  "name": "api",
  "version": "0.1.0",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "dev": "nest start --watch",
    "clean": "node -e \"const fs=require('node:fs'); fs.rmSync('dist', { recursive: true, force: true }); fs.rmSync('tsconfig.build.tsbuildinfo', { force: true }); fs.rmSync('tsconfig.tsbuildinfo', { force: true });\"",
    "build": "pnpm clean && nest build",
    "format": "NODE_OPTIONS=--experimental-strip-types oxfmt --ignore-path ../../.gitignore --write src test drizzle.config.ts",
    "format:check": "NODE_OPTIONS=--experimental-strip-types oxfmt --ignore-path ../../.gitignore --check src test drizzle.config.ts",
    "start": "node dist/main",
    "prestart:dev": "pnpm --filter @seotracker/server build",
    "start:dev": "nest start --watch",
    "prestart:debug": "pnpm --filter @seotracker/server build",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "NODE_OPTIONS=--experimental-strip-types oxlint --ignore-path ../../.gitignore src test drizzle.config.ts",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit",
    "check": "pnpm format && NODE_OPTIONS=--experimental-strip-types oxlint --ignore-path ../../.gitignore --fix src test drizzle.config.ts",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.19",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.19",
    "@nestjs/event-emitter": "^3.1.0",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.19",
    "@nestjs/swagger": "^11.4.2",
    "@nestjs/throttler": "^6.5.0",
    "@node-rs/argon2": "^2.0.2",
    "@seotracker/server": "workspace:*",
    "@seotracker/shared-types": "workspace:*",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cookie-parser": "^1.4.7",
    "drizzle-orm": "0.45.2",
    "helmet": "^8.1.0",
    "nestjs-pino": "^4.6.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.19",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "drizzle-kit": "0.31.10",
    "jest": "^30.3.0",
    "pino-pretty": "^13.1.3",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-loader": "^9.5.7",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.3"
  },
  "jest": {
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testEnvironment": "node",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    }
  }
}
