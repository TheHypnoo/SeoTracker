# ----------------------------------------------------------------------------
# Runtime
# ----------------------------------------------------------------------------
NODE_ENV=development
PORT=4000

# Number of trusted proxy hops in front of the API. Express derives req.ip and
# req.protocol from X-Forwarded-* headers using this value. Never set this to
# `true` — a spoofed X-Forwarded-For would bypass IP-based rate limiting.
#   Local dev:            0 (no proxy)
#   Railway only:         1
#   Railway + Cloudflare: 2
TRUST_PROXY=0

# ----------------------------------------------------------------------------
# Postgres
# ----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/seotracker
PG_POOL_MAX=20
PG_POOL_IDLE_TIMEOUT_MS=30000
PG_POOL_CONNECTION_TIMEOUT_MS=5000

# ----------------------------------------------------------------------------
# Redis (BullMQ + distributed lock)
# ----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# ----------------------------------------------------------------------------
# Auth — JWT and cookies
# ----------------------------------------------------------------------------
# Generate with: openssl rand -base64 48
# Both secrets must be at least 32 chars and must NOT start with `change-this`,
# `__replace_me__` or `replace-me` (env.schema rejects placeholders at boot).
JWT_ACCESS_SECRET=__REPLACE_ME__openssl_rand_base64_48
JWT_REFRESH_SECRET=__REPLACE_ME__openssl_rand_base64_48
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_DAYS=30
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false
CSRF_COOKIE_NAME=csrf_token
REFRESH_COOKIE_NAME=refresh_token
PASSWORD_RESET_TTL_MINUTES=60

# ----------------------------------------------------------------------------
# Webhooks
# ----------------------------------------------------------------------------
WEBHOOK_MAX_SKEW_SECONDS=300

# ----------------------------------------------------------------------------
# SMTP — outbound email
# ----------------------------------------------------------------------------
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="SEOTracker <no-reply@seotracker.local>"
# Gmail SMTP example for TFG/local demos:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=your-account@gmail.com
# SMTP_PASS=your-google-app-password
# SMTP_FROM="SEOTracker <your-account@gmail.com>"

# ----------------------------------------------------------------------------
# Frontend
# ----------------------------------------------------------------------------
APP_URL=http://localhost:3000

# ----------------------------------------------------------------------------
# Audit engine
# ----------------------------------------------------------------------------
AUDIT_CONCURRENCY_GLOBAL=4
AUDIT_CONCURRENCY_PER_PROJECT=1
AUDIT_QUEUE_ATTEMPTS=3
AUDIT_HTTP_TIMEOUT_MS=15000
AUDIT_MAX_LINKS=20
AUDIT_MAX_PAGES=12
AUDIT_MAX_DEPTH=2
AUDIT_SITEMAP_SAMPLE_MAX=50

# ----------------------------------------------------------------------------
# Exports
# ----------------------------------------------------------------------------
EXPORT_CONCURRENCY=2
EXPORT_QUEUE_ATTEMPTS=3
EXPORT_STORAGE_DIR=./storage/exports
EXPORT_TTL_HOURS=48

# ----------------------------------------------------------------------------
# Outbound webhooks
# ----------------------------------------------------------------------------
OUTBOUND_CONCURRENCY=5
OUTBOUND_QUEUE_ATTEMPTS=5

# ----------------------------------------------------------------------------
# Email queue
# ----------------------------------------------------------------------------
EMAIL_CONCURRENCY=3
EMAIL_QUEUE_ATTEMPTS=5

# ----------------------------------------------------------------------------
# Scheduler
# ----------------------------------------------------------------------------
SCHEDULER_LOCK_KEY=scheduler:run-due-schedules
SCHEDULER_LOCK_TTL_MS=90000
SCHEDULER_DUE_WINDOW_MINUTES=5

# ----------------------------------------------------------------------------
# Worker HTTP ports (health + metrics)
# ----------------------------------------------------------------------------
JOBS_HTTP_PORT=4101
SCHEDULER_HTTP_PORT=4102

# ----------------------------------------------------------------------------
# Observability
# ----------------------------------------------------------------------------
# Optional. In production, /metrics returns 404 unless this token is configured.
# Min length 16 chars when set. Generate with: openssl rand -hex 16
METRICS_TOKEN=
BULLMQ_METRICS_INTERVAL_MS=15000

# OpenTelemetry (optional). Enable to ship traces to an OTLP collector.
OTEL_ENABLED=false
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_SERVICE_NAME=seotracker-api

# ----------------------------------------------------------------------------
# Alert webhook (optional)
# ----------------------------------------------------------------------------
# ALERT_WEBHOOK_URL=https://your-webhook.example.com/seotracker
ALERT_WEBHOOK_TIMEOUT_MS=5000
ALERT_WEBHOOK_MIN_INTERVAL_MS=60000
