# The scheduler consumes the same env schema as the API (validated by
# packages/server/src/config/env.schema.ts). Only the variables that the
# `apps/scheduler` runtime actually reads at boot time are listed below; the
# rest resolve to schema defaults.

# ----------------------------------------------------------------------------
# Runtime
# ----------------------------------------------------------------------------
NODE_ENV=development

# ----------------------------------------------------------------------------
# Postgres / Redis
# ----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/seotracker
PG_POOL_MAX=5
PG_POOL_IDLE_TIMEOUT_MS=30000
PG_POOL_CONNECTION_TIMEOUT_MS=5000
REDIS_URL=redis://localhost:6379

# ----------------------------------------------------------------------------
# Auth (scheduler reuses JWT secrets when delivering signed payloads)
# ----------------------------------------------------------------------------
JWT_ACCESS_SECRET=__REPLACE_ME__openssl_rand_base64_48
JWT_REFRESH_SECRET=__REPLACE_ME__openssl_rand_base64_48

# ----------------------------------------------------------------------------
# Scheduling
# ----------------------------------------------------------------------------
SCHEDULER_LOCK_KEY=scheduler:run-due-schedules
SCHEDULER_LOCK_TTL_MS=90000
SCHEDULER_DUE_WINDOW_MINUTES=5

# ----------------------------------------------------------------------------
# Scheduler HTTP server (health + metrics)
# ----------------------------------------------------------------------------
SCHEDULER_HTTP_PORT=4102

# ----------------------------------------------------------------------------
# Observability
# ----------------------------------------------------------------------------
METRICS_TOKEN=
BULLMQ_METRICS_INTERVAL_MS=15000
OTEL_ENABLED=false
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_SERVICE_NAME=seotracker-scheduler
