# Browser-facing API base. Use a relative path so frontend + API share the
# same origin via the Vite/Nitro proxy (configured in vite.config.ts).
VITE_API_URL=/api/v1
# Public asset URL for browser-rendered SVGs/images that cannot rely on the dev proxy.
VITE_PUBLIC_API_URL=http://localhost:4000/api/v1
# Public canonical origin for SEO metadata. Leave empty in local development.
VITE_PUBLIC_SITE_URL=

# Server-to-server URL used by `getServerSession` etc. Must be absolute.
SERVER_API_URL=http://localhost:4000/api/v1
# Upstream target for the Nitro `/api` proxy. In Railway, set it to the API
# private service origin, for example:
# API_PROXY_TARGET=http://${{api.RAILWAY_PRIVATE_DOMAIN}}:4000
API_PROXY_TARGET=http://localhost:4000

VITE_REFRESH_COOKIE_NAME=refresh_token
VITE_CSRF_COOKIE_NAME=csrf_token
