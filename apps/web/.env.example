# Browser-facing API base. Use a relative path so frontend + API share the
# same origin via the Vite/Nitro proxy (configured in vite.config.ts).
VITE_API_URL=/api/v1

# Server-to-server URL used by `getServerSession` etc. Must be absolute.
SERVER_API_URL=http://localhost:4000/api/v1
# Upstream target for the dev-server `/api` proxy.
API_PROXY_TARGET=http://localhost:4000

VITE_REFRESH_COOKIE_NAME=refresh_token
VITE_CSRF_COOKIE_NAME=csrf_token
