{
  "name": "web",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --port 3000",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run --passWithNoTests --config vitest.config.ts",
    "test:cov": "vitest run --coverage --config vitest.config.ts",
    "lint": "oxlint -c .oxlintrc.jsonc --ignore-path ../../.gitignore --ignore-pattern src/routeTree.gen.ts src vite.config.ts vitest.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "format": "oxfmt -c .oxfmtrc.mjs --ignore-path ../../.gitignore --ignore-path .oxfmtignore --write src vite.config.ts vitest.config.ts",
    "format:check": "oxfmt -c .oxfmtrc.mjs --ignore-path ../../.gitignore --ignore-path .oxfmtignore --check src vite.config.ts vitest.config.ts",
    "check": "pnpm format && oxlint -c .oxlintrc.jsonc --ignore-path ../../.gitignore --ignore-pattern src/routeTree.gen.ts --fix src vite.config.ts vitest.config.ts",
    "start": "node .output/server/index.mjs"
  },
  "dependencies": {
    "@seotracker/config-tailwind": "workspace:*",
    "@seotracker/shared-types": "workspace:*",
    "@tailwindcss/vite": "^4.2.4",
    "@tanstack/react-query": "^5.100.9",
    "@tanstack/react-router": "^1.169.2",
    "@tanstack/react-start": "^1.167.65",
    "@tanstack/router-plugin": "^1.167.35",
    "cookie-es": "^3.1.1",
    "nitro": "npm:nitro-nightly@3.0.260429-beta",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwindcss": "^4.2.4",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.11"
  }
}
