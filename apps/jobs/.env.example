# Workers consume the same env schema as the API (validated by
# packages/server/src/config/env.schema.ts). Only the variables that the
# `apps/jobs` runtime actually reads at boot time are listed below; the rest
# resolve to schema defaults.

# ----------------------------------------------------------------------------
# Runtime
# ----------------------------------------------------------------------------
NODE_ENV=development

# ----------------------------------------------------------------------------
# Postgres / Redis
# ----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/seotracker
PG_POOL_MAX=10
PG_POOL_IDLE_TIMEOUT_MS=30000
PG_POOL_CONNECTION_TIMEOUT_MS=5000
REDIS_URL=redis://localhost:6379

# ----------------------------------------------------------------------------
# Auth (workers reuse the same JWT secrets to sign queue payloads where needed)
# ----------------------------------------------------------------------------
JWT_ACCESS_SECRET=__REPLACE_ME__openssl_rand_base64_48
JWT_REFRESH_SECRET=__REPLACE_ME__openssl_rand_base64_48

# ----------------------------------------------------------------------------
# SMTP — workers send transactional email
# ----------------------------------------------------------------------------
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="SEOTracker <no-reply@seotracker.local>"

# Frontend URL — used in transactional email links
APP_URL=http://localhost:3000

# ----------------------------------------------------------------------------
# Queue tuning
# ----------------------------------------------------------------------------
AUDIT_CONCURRENCY_GLOBAL=4
AUDIT_CONCURRENCY_PER_PROJECT=1
AUDIT_QUEUE_ATTEMPTS=3
AUDIT_HTTP_TIMEOUT_MS=15000
AUDIT_MAX_LINKS=20
AUDIT_MAX_PAGES=12
AUDIT_MAX_DEPTH=2
AUDIT_SITEMAP_SAMPLE_MAX=50

EXPORT_CONCURRENCY=2
EXPORT_QUEUE_ATTEMPTS=3
EXPORT_STORAGE_DIR=./storage/exports
EXPORT_TTL_HOURS=48

OUTBOUND_CONCURRENCY=5
OUTBOUND_QUEUE_ATTEMPTS=5

EMAIL_CONCURRENCY=3
EMAIL_QUEUE_ATTEMPTS=5

# ----------------------------------------------------------------------------
# Worker HTTP server (health + metrics)
# ----------------------------------------------------------------------------
JOBS_HTTP_PORT=4101

# ----------------------------------------------------------------------------
# Observability
# ----------------------------------------------------------------------------
METRICS_TOKEN=
BULLMQ_METRICS_INTERVAL_MS=15000
OTEL_ENABLED=false
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_SERVICE_NAME=seotracker-jobs
