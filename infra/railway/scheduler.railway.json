{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "infra/docker/Dockerfile.scheduler",
    "watchPatterns": [
      "apps/scheduler/**",
      "packages/server/**",
      "packages/shared-types/**",
      "packages/config-typescript/**",
      "package.json",
      "pnpm-lock.yaml",
      "pnpm-workspace.yaml",
      "turbo.json",
      "infra/docker/Dockerfile.scheduler",
      "infra/railway/scheduler.railway.json"
    ]
  },
  "deploy": {
    "healthcheckPath": "/health/readiness",
    "healthcheckTimeout": 30,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
