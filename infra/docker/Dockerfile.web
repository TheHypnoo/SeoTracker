FROM node:26.1.0-alpine3.23 AS builder
WORKDIR /app
RUN npm install -g pnpm@11.0.8

# VITE_API_URL and API_PROXY_TARGET are consumed at build time by
# Vite/TanStack Start. In Railway, set API_PROXY_TARGET to the private API
# service origin, for example http://${{api.RAILWAY_PRIVATE_DOMAIN}}:4000.
ARG VITE_API_URL
ARG API_PROXY_TARGET
ENV VITE_API_URL=${VITE_API_URL}
ENV API_PROXY_TARGET=${API_PROXY_TARGET}

COPY package.json pnpm-workspace.yaml pnpm-lock.yaml turbo.json ./
COPY packages ./packages
COPY apps/web ./apps/web

RUN pnpm install --frozen-lockfile --ignore-scripts
RUN pnpm turbo run build --filter=web...
RUN pnpm --filter web --prod --ignore-scripts --legacy deploy /deploy

FROM node:26.1.0-alpine3.23 AS runtime
WORKDIR /app
ENV NODE_ENV=production
RUN apk add --no-cache wget
COPY --from=builder --chown=node:node /deploy/node_modules ./node_modules
COPY --from=builder --chown=node:node /app/apps/web/.output ./.output
COPY --from=builder --chown=node:node /app/apps/web/package.json ./package.json

USER node
EXPOSE 3000
HEALTHCHECK --interval=30s --timeout=5s --start-period=20s --retries=3 \
  CMD wget --quiet --spider http://localhost:${PORT:-3000}/health || exit 1
CMD ["node", ".output/server/index.mjs"]
